# PostgreSQL used by Prisma.
DATABASE_URL="postgresql://pinbead:pinbead@localhost:5432/pinbead?schema=public"

# First admin account. Generate ADMIN_PASSWORD_HASH with a strong password hash.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH=""
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"
ADMIN_SESSION_MAX_AGE="604800"

# Public asset uploads for admin-managed previews and downloads.
UPLOAD_DIR="/var/lib/pinbead/uploads"
UPLOAD_PUBLIC_BASE_URL="/uploads"

# Optional future integrations.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
SENTRY_DSN=""
GA_MEASUREMENT_ID=""
ADSENSE_CLIENT_ID=""
