generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  ADMIN

  @@map("admin_role")
}

enum ContentStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")

  @@map("content_status")
}

enum PatternDifficulty {
  BEGINNER @map("beginner")
  EASY     @map("easy")
  MEDIUM   @map("medium")
  HARD     @map("hard")

  @@map("pattern_difficulty")
}

enum PatternSourceType {
  ORIGINAL        @map("original")
  AI_ASSISTED     @map("ai_assisted")
  PUBLIC_DOMAIN   @map("public_domain")
  LICENSED        @map("licensed")
  USER_SUBMISSION @map("user_submission")

  @@map("pattern_source_type")
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}

model Category {
  id             String        @id @default(cuid())
  slug           String        @unique
  name           String
  description    String?       @db.Text
  seoTitle       String?
  seoDescription String?       @db.Text
  sortOrder      Int           @default(0)
  status         ContentStatus @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  patterns       Pattern[]

  @@index([status, sortOrder])
  @@map("categories")
}

model Pattern {
  id               String              @id @default(cuid())
  slug             String              @unique
  title            String
  summary          String?             @db.Text
  description      String?             @db.Text
  categoryId       String?
  category         Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  difficulty       PatternDifficulty   @default(BEGINNER)
  width            Int
  height           Int
  colorCount       Int                 @default(0)
  beadCount        Int                 @default(0)
  paletteId        String
  cellsJson        Json
  previewImageUrl  String?
  downloadImageUrl String?
  sourceType       PatternSourceType   @default(ORIGINAL)
  seoTitle         String?
  seoDescription   String?             @db.Text
  status           ContentStatus       @default(DRAFT)
  publishedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@index([difficulty])
  @@map("patterns")
}

model Guide {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  summary        String?       @db.Text
  content        String?       @db.Text
  seoTitle       String?
  seoDescription String?       @db.Text
  status         ContentStatus @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, publishedAt])
  @@map("guides")
}
